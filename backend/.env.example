# =============================================================================
# RecallX Backend Environment Configuration
# =============================================================================
# Copy this file to .env and update with your actual values
# Command: cp .env.example .env (Linux/Mac) or copy .env.example .env (Windows)

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string format:
# postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
#
# IMPORTANT SETUP STEPS:
# 1. Install PostgreSQL (https://www.postgresql.org/download/)
# 2. Start PostgreSQL service
# 3. Create the recallx database:
#    - Option 1 (Command line): createdb recallx
#    - Option 2 (psql): psql -U postgres
#                       CREATE DATABASE recallx;
#                       \q
# 4. Update USERNAME and PASSWORD below with your PostgreSQL credentials
# 5. Default PostgreSQL port is 5432
#
DATABASE_URL=postgresql://YOUR_POSTGRES_USERNAME:YOUR_POSTGRES_PASSWORD@localhost:5432/recallx

# =============================================================================
# JWT Authentication Configuration
# =============================================================================
# SECRET_KEY: Used to sign JWT tokens. MUST be kept secret and changed in production.
# Generate a secure key using one of these methods:
#   - Python: python -c "import secrets; print(secrets.token_hex(32))"
#   - OpenSSL: openssl rand -hex 32
#   - Online: https://generate-secret.vercel.app/32
#
SECRET_KEY=your-secret-key-change-this-to-a-random-string-in-production

# JWT algorithm (HS256 is recommended for symmetric signing)
ALGORITHM=HS256

# Token expiration in days (7 days = 1 week)
ACCESS_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS Configuration (Cross-Origin Resource Sharing)
# =============================================================================
# Comma-separated list of allowed origins that can make requests to this API.
#
# LOCAL DEVELOPMENT DEFAULT:
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost
#
# PRODUCTION EXAMPLE (Vercel Frontend + Render Backend):
# Uncomment and update the domain names with your actual deployment URLs:
# BACKEND_CORS_ORIGINS=https://kinda-quiz.vercel.app,http://localhost:5173,http://localhost
#
# MULTIPLE ORIGINS FORMAT:
# Simply separate each origin with a comma (no spaces between origins):
# BACKEND_CORS_ORIGINS=https://app.example.com,https://www.example.com,http://localhost:5173
#
# IMPORTANT:
# - Include the protocol (http:// or https://)
# - Include the port if not default (5173 for Vite, 80 for http, 443 for https)
# - Do NOT include trailing slashes
# - For production, always use HTTPS origins
#

# =============================================================================
# Cookie Security Configuration
# =============================================================================
# Security settings for authentication cookies sent to the client.
#
# COOKIE_SECURE: Set to 'true' to mark cookies as Secure (HTTPS only)
#   - Local Development: false (uses HTTP)
#   - Production: true (requires HTTPS in production)
#
COOKIE_SECURE=false

# COOKIE_SAMESITE: SameSite policy for cookies
#   - lax: Cookies sent with same-site requests and top-level navigations (RECOMMENDED)
#   - strict: Cookies only sent with same-site requests
#   - none: Cookies sent with all requests (requires COOKIE_SECURE=true)
#
COOKIE_SAMESITE=lax

# =============================================================================
# Production Configuration Example (Render + Vercel)
# =============================================================================
# When deploying to production on Render, use these environment variables:
#
# DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxxx.region.aws.neon.tech/database?sslmode=require
# SECRET_KEY=<generate-with-commands-above>
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_DAYS=7
# BACKEND_CORS_ORIGINS=https://kinda-quiz.vercel.app,http://localhost:5173,http://localhost
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
#
# Set these variables in Render Dashboard:
# 1. Go to your service dashboard
# 2. Navigate to Environment section
# 3. Add each variable with its value
# 4. Redeploy the service
#

# =============================================================================
# Notes
# =============================================================================
# - Never commit the .env file to version control (.env is in .gitignore)
# - Use strong passwords for PostgreSQL in production
# - Generate a new SECRET_KEY for each environment (dev, staging, production)
# - Ensure PostgreSQL is running before starting the backend
# - Test connection: python -c "from app.core.database import engine; engine.connect(); print('✓ Connected')"
# - For CORS issues in production, verify BACKEND_CORS_ORIGINS includes the frontend domain
# - For browser console CORS errors, check the Origin header matches a configured origin
